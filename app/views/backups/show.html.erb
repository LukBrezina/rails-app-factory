<section class="p-7 max-w-3xl w-full mx-auto">
  <div class="flex items-baseline gap-4 mb-2">
    <h2 class="text-[11px] font-medium tracking-[0.3em] text-dim uppercase">Backups · <%= @app.display_name %></h2>
    <span class="flex-1 border-t border-line-soft"></span>
    <span class="text-[11px] <%= @app.backups_configured? ? "text-live" : "text-idle" %>">
      <%= @app.backups_configured? ? "on" : "not set up yet" %>
    </span>
  </div>
  <p class="text-[11px] text-dim leading-relaxed mt-0 mb-6 max-w-2xl">
    Everything your live app saves is copied to safe storage within 30 seconds, around the clock.
    You can rewind the live app to any moment — and nothing and nobody can delete the history,
    even with stolen passwords.
  </p>

  <% unless ENV["APPSMOOTHLY_S3_BUCKET"].present? # provisioned boxes: storage came with the machine %>
  <div class="border border-line bg-panel clip-tag p-6 mb-6 text-[11px] text-dim leading-relaxed">
    <details open>
      <summary class="cursor-pointer text-idle tracking-[0.08em]">SET UP THE STORAGE (GOOGLE CLOUD) — ONCE PER APP, ~5 MINUTES</summary>
      <ol class="mt-3 pl-5 space-y-1.5">
        <li>Google Cloud Console → Cloud Storage → <strong class="text-strong">Create bucket</strong> (a bucket is just a storage box in the cloud).
          Under "Protection", set a <strong class="text-strong">retention policy</strong> of e.g. 30 days — this is the magic bit:
          the cloud itself refuses to let anything be deleted or changed before it's that old, no matter who asks.</li>
        <li>IAM → create a <strong class="text-strong">service account</strong> (a robot user just for this app) with roles
          <strong class="text-strong">Storage Object Creator</strong> and <strong class="text-strong">Storage Object Viewer</strong> —
          it can write and read, never delete.</li>
        <li>Cloud Storage → Settings → <strong class="text-strong">Interoperability</strong> → create an
          <strong class="text-strong">HMAC key</strong> for that robot user. That's the key + secret for the form below.</li>
        <li>Endpoint below: <code class="text-strong">https://storage.googleapis.com</code>. Region: anything.</li>
      </ol>
      <p class="mt-2 mb-0">The backup tool occasionally complains it can't tidy up old history — that's the protection working. History piles up; storage is cheap, your data is not.</p>
    </details>
  </div>

  <%= form_with model: @app, url: backups_path, method: :patch, class: "border border-line bg-panel clip-tag p-6 mb-6" do |f| %>
    <div class="text-[10px] tracking-[0.3em] text-faint mb-5">STORAGE KEYS</div>
    <div class="grid grid-cols-2 gap-x-6 gap-y-5">
      <% { s3_bucket: "myapp-backups", s3_region: "auto", s3_endpoint: "https://storage.googleapis.com",
           s3_access_key_id: "GOOG…", s3_secret_access_key: "•••" }.each do |field, placeholder| %>
        <div class="<%= "col-span-2" if field == :s3_endpoint %>">
          <label class="block text-[10px] tracking-[0.2em] text-faint mb-1"><%= field.to_s.delete_prefix("s3_").tr("_", " ").upcase %></label>
          <%= f.send(field == :s3_secret_access_key ? :password_field : :text_field, field,
                placeholder: placeholder, autocomplete: "off", value: @app.public_send(field),
                class: "w-full bg-transparent border-0 border-b border-line focus:border-live text-strong text-[13px] px-0.5 py-1.5 placeholder:text-faint outline-none") %>
        </div>
      <% end %>
    </div>
    <button class="mt-6 font-medium text-[11px] tracking-[0.16em] text-bg bg-live hover:brightness-110 px-5 py-2.5 clip-tag cursor-pointer">SAVE</button>
    <span class="ml-3 text-[11px] text-faint">Backups start the next time you put the app live. Keys never leave this machine.</span>
  <% end %>
  <% end %>

  <% if @app.backups_configured? %>
    <div class="border border-line bg-panel clip-tag p-6 mb-6">
      <div class="text-[10px] tracking-[0.3em] text-faint mb-3">BACKUP STATUS</div>
      <pre class="text-[10px] text-dim bg-panel-2 border border-line-soft p-3 overflow-x-auto m-0"><%= @status %></pre>
    </div>

    <div class="border border-danger/40 bg-danger/5 clip-tag p-6 mb-6">
      <div class="text-[10px] tracking-[0.3em] text-danger mb-2">REWIND THE LIVE APP</div>
      <p class="text-[11px] text-dim mt-0 mb-4 leading-relaxed max-w-xl">
        Something went badly wrong? Pick the moment everything was still fine, and the live app's
        data goes back to exactly that second. Nothing is lost — even the rewound-away part stays
        in the backup history.
      </p>
      <%= form_with url: backups_restore_path, method: :post, class: "flex items-end gap-4" do %>
        <div>
          <label class="block text-[10px] tracking-[0.2em] text-faint mb-1">DATE &amp; TIME (UTC)</label>
          <input type="datetime-local" name="timestamp" required step="1"
                 class="bg-transparent border-0 border-b border-line focus:border-danger text-strong text-[13px] px-0.5 py-1.5 outline-none">
        </div>
        <button class="font-medium text-[11px] tracking-[0.16em] text-bg bg-danger hover:brightness-110 px-5 py-2.5 clip-tag cursor-pointer"
                onclick="return confirm('Pause the live app and rewind its data to this moment? Everything saved after it will disappear from the app — but stays in the backup history.')">REWIND →</button>
      <% end %>
    </div>

    <div class="border border-line bg-panel clip-tag p-6">
      <div class="text-[10px] tracking-[0.3em] text-faint mb-2">TRY THINGS ON REAL DATA</div>
      <p class="text-[11px] text-dim mt-0 mb-4 leading-relaxed max-w-xl">
        Copy the latest live data into a session, so you and Claude can test with the real thing.
        The live app itself is never touched.
      </p>
      <% if @sessions.any? %>
        <% @sessions.each do |s| %>
          <div class="flex items-center gap-3 py-1.5 border-b border-line-soft last:border-0">
            <span class="dot" data-state="<%= s.attached? ? "live" : "idle" %>"></span>
            <span class="flex-1 text-[13px] font-medium text-strong"><%= s.name %></span>
            <%= button_to "COPY LIVE DATA HERE →", backups_pull_path(s.name), method: :post,
                  class: "text-[10px] tracking-[0.14em] text-idle border border-idle/40 px-3 py-1.5 clip-tag hover:bg-idle/10 cursor-pointer bg-transparent",
                  form: { class: "contents" } %>
          </div>
        <% end %>
      <% else %>
        <p class="text-[11px] text-faint m-0">No sessions running — start one under SESSIONS first.</p>
      <% end %>
    </div>
  <% end %>
</section>
