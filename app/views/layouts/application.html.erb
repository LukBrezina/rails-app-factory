<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails App Factory" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,500;1,9..144,600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-dvh flex flex-col bg-bg text-ink font-mono text-[13px] leading-relaxed antialiased">
    <header class="flex items-center gap-7 px-7 py-3.5 border-b border-line bg-linear-to-b from-panel to-transparent shrink-0">
      <a class="font-serif italic font-semibold text-[21px] text-strong tracking-tight" href="<%= root_path %>">Rails App Factory</a>
      <nav class="flex items-center gap-2 overflow-x-auto">
        <% App.order(:created_at).each do |a| %>
          <a href="<%= sessions_path(a) %>"
             class="px-3 py-1 text-[11px] tracking-[0.12em] border clip-tag whitespace-nowrap transition-colors
                    <%= a == @app ? "border-strong/40 text-strong bg-panel-2" : "border-line text-dim hover:text-ink hover:bg-panel" %>"><%= a.display_name %></a>
        <% end %>
        <a href="<%= new_app_path %>" class="px-2.5 py-1 text-[11px] tracking-[0.12em] border border-dashed border-line text-faint hover:text-live hover:border-live/40 whitespace-nowrap">+ ADD APP</a>
      </nav>
      <span class="ml-auto text-[11px] text-faint tracking-[0.08em] hidden sm:block"><%= Socket.gethostname %></span>
    </header>

    <% if flash[:alert] || flash[:notice] %>
      <p class="mx-7 mt-4 px-3.5 py-2.5 text-xs border clip-tag <%= flash[:alert] ? "border-danger text-danger bg-danger/5" : "border-live/40 text-live bg-live/5" %>">
        <%= flash[:alert] || flash[:notice] %>
      </p>
    <% end %>

    <div class="flex flex-1 min-h-0">
      <% if @app&.persisted? %>
        <aside class="w-44 shrink-0 border-r border-line-soft p-5">
          <div class="text-[10px] tracking-[0.3em] text-faint mb-3">MENU</div>
          <% [["SESSIONS", sessions_path(@app), "sessions"],
              ["GO LIVE", production_path(@app), "productions"],
              ["BACKUPS", backups_path(@app), "backups"]].each do |label, path, ctrl| %>
            <a class="block px-3 py-2 mb-1 text-[11px] tracking-[0.16em] border-l-2
                      <%= controller_name == ctrl ? "text-live border-live bg-panel" : "text-dim border-transparent hover:text-ink" %>"
               href="<%= path %>"><%= label %></a>
          <% end %>
        </aside>
      <% end %>
      <main class="flex-1 flex flex-col min-h-0 min-w-0 overflow-auto">
        <%= yield %>
      </main>
    </div>

    <% if @app&.persisted? %>
      <script>
        // live state poll — refreshes dots, titles, chips and preview links in place
        const tagged = () => document.querySelectorAll("[data-session-name]")
        if (tagged().length) setInterval(async () => {
          try {
            const list = await (await fetch("<%= sessions_path(@app, format: :json) %>")).json()
            const by = Object.fromEntries(list.map(s => [s.name, s]))
            tagged().forEach(el => {
              const s = by[el.dataset.sessionName]
              el.classList.toggle("gone", !s)
              if (!s) return
              el.querySelectorAll("[data-dot]").forEach(d => d.dataset.state = s.attached ? "live" : "idle")
              el.querySelectorAll("[data-title]").forEach(t => t.textContent = s.title || s.command)
              el.querySelectorAll("[data-cmd]").forEach(c => { c.textContent = s.command; c.dataset.claude = s.claude })
              el.querySelectorAll("[data-preview]").forEach(a => {
                a.classList.toggle("hidden", !s.preview_url)
                if (s.preview_url) a.href = s.preview_url
              })
            })
            const count = document.querySelector("[data-count]")
            if (count) count.textContent = `${list.length} session${list.length === 1 ? "" : "s"} · ${list.filter(s => s.attached).length} open in a browser`
          } catch {}
        }, 4000)
      </script>
    <% end %>
  </body>
</html>
