<section class="p-7 max-w-4xl w-full mx-auto">
  <div class="flex items-baseline gap-4 mb-2">
    <h2 class="text-[11px] font-medium tracking-[0.3em] text-dim uppercase">Test inbox · <%= @session %></h2>
    <span class="flex-1 border-t border-line-soft"></span>
    <a class="text-[11px] text-faint tracking-[0.08em] hover:text-ink whitespace-nowrap" href="<%= session_path(@session) %>">← back to session</a>
  </div>
  <p class="text-[11px] text-dim leading-relaxed mt-0 mb-6 max-w-2xl">
    Emails your app tried to send while you were testing land here instead of reaching real
    people. Open one to read it<%= Mailbox.smtp_configured? ? " — or send a copy to a real inbox." : "." %>
  </p>

  <% if @messages.empty? %>
    <div class="border border-dashed border-line clip-tag p-8 text-center text-[12px] text-faint">
      No emails yet. Click around your test app — anything it sends shows up here.
    </div>
  <% else %>
    <div class="flex flex-col gap-2">
      <% @messages.each do |m| %>
        <a href="<%= session_mail_path(@session, m.id) %>"
           class="card bg-panel border border-line hover:border-line-hover hover:bg-panel-2 transition-colors clip-tag px-4 py-3 flex items-center gap-4">
          <div class="min-w-0 flex-1">
            <div class="text-[13px] font-medium text-strong truncate"><%= m.subject %></div>
            <div class="text-[11px] text-dim truncate">to <%= m.to %></div>
          </div>
          <time class="text-[10px] text-faint tracking-[0.06em] shrink-0"><%= m.date.strftime("%b %-d, %H:%M") %></time>
        </a>
      <% end %>
    </div>
  <% end %>
</section>
