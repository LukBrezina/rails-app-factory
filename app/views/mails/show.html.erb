<section class="p-7 max-w-4xl w-full mx-auto">
  <div class="flex items-baseline gap-4 mb-4">
    <h2 class="text-[11px] font-medium tracking-[0.3em] text-dim uppercase">Test inbox · <%= @session %></h2>
    <span class="flex-1 border-t border-line-soft"></span>
    <a class="text-[11px] text-faint tracking-[0.08em] hover:text-ink whitespace-nowrap" href="<%= session_mails_path(@session) %>">← all emails</a>
  </div>

  <article class="border border-line bg-panel clip-tag">
    <div class="px-5 py-4 border-b border-line-soft">
      <div class="text-[16px] font-medium text-strong mb-2 break-words"><%= @message.subject %></div>
      <dl class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-0.5 text-[11px]">
        <dt class="text-faint">from</dt><dd class="text-dim break-all"><%= @message.from %></dd>
        <dt class="text-faint">to</dt><dd class="text-dim break-all"><%= @message.to %></dd>
        <dt class="text-faint">when</dt><dd class="text-dim"><%= @message.date.strftime("%B %-d, %Y at %H:%M") %></dd>
      </dl>
    </div>
    <%# sandbox (no value) = no scripts/forms/same-origin; srcdoc is escaped by Rails then decoded by the browser %>
    <iframe title="email preview" sandbox class="w-full block bg-white" style="height:60vh;border:0"
            srcdoc="<%= @message.body_html %>"></iframe>
  </article>

  <div class="mt-5 border border-line bg-panel-2 clip-tag px-5 py-4">
    <div class="text-[10px] tracking-[0.3em] text-faint mb-3">SEND A COPY TO A REAL INBOX</div>
    <% if Mailbox.smtp_configured? %>
      <%= form_with url: forward_session_mail_path(@session, @message.id), method: :post, class: "flex gap-2.5 items-end" do %>
        <input name="to" type="email" required placeholder="you@example.com" autocomplete="off"
               class="flex-1 min-w-0 bg-transparent border-0 border-b border-line focus:border-live text-strong text-[14px] px-0.5 py-1 placeholder:text-faint outline-none">
        <button class="font-medium text-[11px] tracking-[0.14em] text-bg bg-live hover:brightness-110 px-3.5 py-2 clip-tag cursor-pointer">SEND →</button>
      <% end %>
      <p class="text-[10px] text-faint leading-relaxed mt-2 mb-0">Delivers this exact email to the address you type, using the factory's mail settings.</p>
    <% else %>
      <p class="text-[11px] text-idle m-0 leading-relaxed">Not set up yet. Add <code>APPSMOOTHLY_SMTP_ADDRESS</code>, <code>APPSMOOTHLY_SMTP_USER_NAME</code> and <code>APPSMOOTHLY_SMTP_PASSWORD</code> (optionally <code>APPSMOOTHLY_SMTP_PORT</code>, <code>APPSMOOTHLY_SMTP_FROM</code>) to the factory's environment, and a send button appears here.</p>
    <% end %>
  </div>
</section>
