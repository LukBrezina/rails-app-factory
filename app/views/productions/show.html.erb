<section class="p-7 max-w-3xl w-full mx-auto">
  <div class="flex items-baseline gap-4 mb-2">
    <h2 class="text-[11px] font-medium tracking-[0.3em] text-dim uppercase">Go live · <%= @app.display_name %></h2>
    <span class="flex-1 border-t border-line-soft"></span>
    <% if @app.deployed_at? %>
      <span class="text-[11px] text-faint">last went live <%= time_ago_in_words(@app.deployed_at) %> ago</span>
    <% end %>
  </div>
  <p class="text-[11px] text-dim leading-relaxed mt-0 mb-6 max-w-2xl">
    "Live" (production) is the real version of your app — the one anyone can visit at your web
    address, with real data. It runs on its own server, separate from the sessions where you
    and Claude experiment.
  </p>

  <div class="border border-line bg-panel clip-tag p-6 mb-6 text-[11px] text-dim leading-relaxed">
    <div class="text-[10px] tracking-[0.3em] text-faint mb-3">STEP 1 — GET A SERVER (ONCE)</div>
    <p class="m-0 mb-2">Rent a small Ubuntu server from any provider (Hetzner, DigitalOcean…). Log in to it once and paste:</p>
    <pre class="text-[10px] text-strong bg-panel-2 border border-line-soft p-3 overflow-x-auto m-0">curl -fsSL https://tailscale.com/install.sh | sh &amp;&amp; sudo tailscale up --ssh</pre>
    <p class="m-0 mt-2">
      That connects it to your private tailscale network — after that, everything else is automatic
      and you never need to log in to it again. One-time setting: in the tailscale admin page, change
      the ssh rule's <code>"action": "check"</code> to <code>"accept"</code> so going live never stops
      to ask for approval. One server can host several apps.
    </p>
  </div>

  <%= form_with model: @app, url: production_path(@app), method: :patch, class: "border border-line bg-panel clip-tag p-6 mb-6" do |f| %>
    <div class="text-[10px] tracking-[0.3em] text-faint mb-5">STEP 2 — WHERE YOUR APP WILL LIVE</div>
    <div class="grid grid-cols-2 gap-6">
      <div>
        <label class="block text-[10px] tracking-[0.2em] text-faint mb-1">SERVER NAME (FROM TAILSCALE)</label>
        <%= f.text_field :prod_server, placeholder: "prod-1 or 100.x.y.z", autocomplete: "off",
              class: "w-full bg-transparent border-0 border-b border-line focus:border-live text-strong text-[14px] px-0.5 py-1.5 placeholder:text-faint outline-none" %>
      </div>
      <div>
        <label class="block text-[10px] tracking-[0.2em] text-faint mb-1">WEB ADDRESS</label>
        <%= f.text_field :prod_host, placeholder: "myapp.example.com", autocomplete: "off",
              class: "w-full bg-transparent border-0 border-b border-line focus:border-live text-strong text-[14px] px-0.5 py-1.5 placeholder:text-faint outline-none" %>
      </div>
    </div>
    <button class="mt-6 font-medium text-[11px] tracking-[0.16em] text-bg bg-live hover:brightness-110 px-5 py-2.5 clip-tag cursor-pointer">SAVE</button>
  <% end %>

  <% if @app.prod_server.present? && @app.prod_host.present? %>
    <div class="border border-line bg-panel clip-tag p-6 mb-6">
      <div class="text-[10px] tracking-[0.3em] text-faint mb-4">STEP 3 — POINT YOUR WEB ADDRESS AT THE SERVER</div>
      <p class="text-[11px] text-dim mt-0 mb-3 leading-relaxed">
        Wherever you bought your domain, add this record so the address leads to your server:
      </p>
      <table class="w-full text-[12px]">
        <tr class="text-[10px] tracking-[0.2em] text-faint text-left">
          <th class="pb-2 font-normal">TYPE</th><th class="pb-2 font-normal">NAME</th><th class="pb-2 font-normal">VALUE</th>
        </tr>
        <tr class="text-ink">
          <td class="py-1 pr-6">A</td>
          <td class="py-1 pr-6 font-medium text-strong"><%= @app.prod_host %></td>
          <td class="py-1 font-medium text-strong">the server's public IP — shown in your server provider's panel</td>
        </tr>
      </table>
      <p class="text-[11px] text-faint mt-3 leading-relaxed m-0">
        It can take a few minutes to start working. Wait until it does before the first launch —
        the secure <code>https</code> certificate for <%= @app.prod_host %> is created automatically, and it needs the address to resolve.
      </p>
    </div>

    <div class="flex items-center gap-4">
      <%= button_to (@app.deployed_at? ? "PUT THE LATEST VERSION LIVE →" : "GO LIVE →"), deploy_production_path(@app),
            class: "font-medium text-[11px] tracking-[0.16em] px-5 py-2.5 clip-tag cursor-pointer #{@app.deployable? ? "text-bg bg-live hover:brightness-110" : "text-faint bg-panel-2 cursor-not-allowed"}",
            disabled: !@app.deployable?,
            form: { onsubmit: "return confirm('Put #{@app.display_name} live at #{@app.prod_host}?')" } %>
      <span class="text-[11px] text-faint">Everything is automatic — you can watch it happen live.</span>
    </div>
    <% unless @app.backups_configured? %>
      <p class="text-[11px] text-idle mt-4">Backups aren't set up yet — do that under BACKUPS before real people put real data in.</p>
    <% end %>
  <% end %>
</section>
