<section class="p-7 max-w-5xl w-full mx-auto">
  <div class="flex items-baseline gap-4 mb-2">
    <h2 class="text-[11px] font-medium tracking-[0.3em] text-dim uppercase">Sessions · <%= @app.display_name %></h2>
    <span class="flex-1 border-t border-line-soft"></span>
    <span class="text-[11px] text-faint tracking-[0.08em]" data-count><%= @sessions.size %> session<%= "s" unless @sessions.size == 1 %> · <%= @sessions.count(&:attached?) %> open in a browser</span>
  </div>
  <p class="text-[11px] text-dim leading-relaxed mt-0 mb-6 max-w-2xl">
    A session is a private workspace where Claude changes a copy of your app — with its own
    test version you can click around in. Test data here is temporary and separate from your
    live app. Closing the browser never stops Claude.
  </p>

  <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-3.5">
    <article class="card border border-dashed border-line clip-tag p-5 flex flex-col justify-center gap-3.5 min-h-[150px]">
      <div class="text-[10px] tracking-[0.3em] text-faint">NEW SESSION</div>
      <% if @app.ready? %>
        <%= form_with url: sessions_path(@app), method: :post, class: "flex gap-2.5 items-end" do %>
          <input name="name" placeholder="What you are building" required autocomplete="off"
                 class="flex-1 min-w-0 bg-transparent border-0 border-b border-line focus:border-live text-strong text-[15px] font-medium px-0.5 py-1 placeholder:text-faint outline-none">
          <button class="font-medium text-[11px] tracking-[0.14em] text-bg bg-live hover:brightness-110 px-3.5 py-2 clip-tag cursor-pointer">START →</button>
        <% end %>
        <p class="text-[10px] text-faint leading-relaxed m-0">Give it a short name. Claude and a test version of your app start automatically.</p>
      <% else %>
        <p class="text-[11px] text-idle m-0">Your app is still being built — watch it happen in the <em>setup</em> session below.</p>
      <% end %>
    </article>

    <% @sessions.each do |s| %>
      <article class="card bg-panel border border-line hover:border-line-hover hover:bg-panel-2 transition-colors clip-tag p-4 flex flex-col gap-2.5" data-session-name="<%= s.name %>">
        <header class="flex items-center gap-2.5">
          <span class="dot" data-dot data-state="<%= s.attached? ? "live" : "idle" %>"></span>
          <h3 class="flex-1 m-0 text-[15px] font-medium text-strong break-all leading-tight"><%= s.name %></h3>
          <span class="cmd" data-cmd data-claude="<%= s.claude? %>"><%= s.display_command %></span>
        </header>
        <p class="m-0 min-h-[2.6em] text-xs text-dim italic line-clamp-2" data-title><%= s.title || s.display_command %></p>
        <footer class="flex items-center gap-3 border-t border-line-soft pt-2.5">
          <span class="flex-1 text-[10px] text-faint tracking-[0.06em]">running <%= time_ago_in_words(s.created_at) %></span>
          <a data-preview target="_blank" href="<%= s.preview_url(preview_host) %>"
             class="text-[10px] tracking-[0.14em] text-idle border border-idle/40 px-2 py-1 clip-tag hover:bg-idle/10 <%= "hidden" unless s.port %>"
             title="Open the test version of your app">TRY IT ↗</a>
          <a href="<%= session_mails_path(@app, s.name) %>" title="Emails your app sent while testing"
             class="text-[10px] tracking-[0.14em] text-idle border border-idle/40 px-2 py-1 clip-tag hover:bg-idle/10 <%= "hidden" unless s.port %>">INBOX ✉</a>
          <a class="group text-[11px] tracking-[0.14em] text-live border border-live/40 px-3 py-1 clip-tag hover:bg-live/10" href="<%= session_path(@app, s.name) %>">OPEN <span class="inline-block transition-transform group-hover:translate-x-0.5">→</span></a>
          <%= button_to "✕", session_path(@app, s.name), method: :delete,
                class: "text-faint hover:text-danger cursor-pointer bg-transparent border-0 p-1 font-mono text-[13px]",
                form: { class: "contents", onsubmit: "return confirm('End this session? The workspace is cleaned up, but everything Claude saved stays in your project history.')" } %>
        </footer>
      </article>
    <% end %>
  </div>
</section>
