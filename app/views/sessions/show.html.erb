<% content_for :title, @session.display_title %>

<div class="px-4 sm:px-6 pt-3 shrink-0 flex items-stretch gap-1.5">
  <nav class="flex-1 min-w-0 flex items-stretch gap-1.5 overflow-x-auto [scrollbar-width:none]">
    <% @sessions.each do |s| %>
      <a class="flex items-center gap-2 px-3 py-2 border border-b-0 clip-tag max-w-[240px] shrink-0 transition-colors
                <%= s.name == @name ? "border-line bg-panel-2 text-strong shadow-[inset_0_2px_0_var(--color-live)]" : "border-line bg-panel text-dim hover:text-ink hover:bg-panel-2" %>"
         href="<%= session_path(s.name) %>" data-session-name="<%= s.name %>">
        <span class="dot" data-dot data-state="<%= s.state %>"></span>
        <span class="text-[12.5px] font-medium whitespace-nowrap overflow-hidden text-ellipsis" data-title><%= s.display_title %></span>
      </a>
    <% end %>
    <%= button_to "+", sessions_path, method: :post, title: "New session", form: { class: "contents" },
          class: "flex items-center px-3.5 py-2 border border-b-0 border-line bg-panel clip-tag text-faint hover:text-live text-[15px] shrink-0 cursor-pointer" %>
  </nav>

  <div class="flex items-stretch gap-1.5 shrink-0 pl-1.5">
    <%= button_to "DEPLOY", deploy_production_path, form: { class: "contents",
          onsubmit: "return confirm('Put your app live now? Everything is automatic and you can watch it happen.')" },
          class: "flex items-center px-3 py-2 clip-tag text-[10px] tracking-[0.14em] font-medium text-bg bg-live hover:brightness-110 cursor-pointer" %>
    <a href="<%= versions_path %>" class="flex items-center px-3 py-2 clip-tag text-[10px] tracking-[0.14em] font-medium text-idle border border-idle/50 hover:bg-idle/10">VERSIONS</a>
  </div>
</div>

<div class="flex-1 min-h-0 flex flex-col mx-4 sm:mx-6 mb-4 border border-line bg-panel-2 clip-tag" data-session-name="<%= @name %>">
  <div class="flex items-center gap-2.5 px-3 py-2 border-b border-line-soft text-xs shrink-0">
    <span class="dot" data-dot data-state="<%= @session.state %>"></span>
    <strong class="min-w-0 font-medium text-strong whitespace-nowrap overflow-hidden text-ellipsis" data-title><%= @session.display_title %></strong>
    <span class="flex items-center gap-1.5 shrink-0 ml-auto">
      <button id="mic" type="button" hidden title="Dictate — speak instead of type"
              class="text-[13px] leading-none px-2 py-1 clip-tag border border-idle/40 text-idle hover:bg-idle/10 cursor-pointer data-[on=true]:text-danger data-[on=true]:border-danger/60 data-[on=true]:bg-danger/5">🎤</button>
      <a data-preview target="_blank" href="<%= @session.preview_url(preview_host) %>"
         title="Open the test version of your app"
         class="text-[10px] tracking-[0.14em] text-idle border border-idle/40 px-2.5 py-1 clip-tag hover:bg-idle/10 <%= "hidden" unless @session.port %>">TRY IT ↗</a>
      <a href="<%= session_mails_path(@name) %>" title="Emails your app sent while testing"
         class="text-[10px] tracking-[0.14em] text-idle border border-idle/40 px-2.5 py-1 clip-tag hover:bg-idle/10 <%= "hidden" unless @session.port %>">INBOX ✉</a>
      <%= button_to "✕", session_path(@name), method: :delete, title: "End this session",
            class: "text-faint hover:text-danger cursor-pointer bg-transparent border-0 p-1 font-mono text-xs",
            form: { class: "contents", onsubmit: "return confirm('End this session? The workspace is cleaned up, but everything Claude saved stays in your project history.')" } %>
    </span>
  </div>
  <div id="terminal" class="flex-1 min-h-0 overflow-hidden"></div>
</div>

<%= render "shared/terminal", token: @token %>
