<%# Browser terminal attached to the tmux session named by the signed token.
    xterm is vendored (vendor/javascript) — this page mints a shell-capability
    token, so no third-party JS. Render into a container with id "terminal". %>
<% content_for :head do %>
  <link rel="stylesheet" href="<%= asset_path("xterm.min.css") %>">
  <script src="<%= asset_path("xterm.min.js") %>"></script>
  <script src="<%= asset_path("addon-fit.min.js") %>"></script>
<% end %>

<script type="module">
  import { createConsumer } from "@rails/actioncable"

  await document.fonts.load('13px "IBM Plex Mono"') // xterm measures glyphs at open()

  const term = new Terminal({
    fontSize: 13,
    fontFamily: '"IBM Plex Mono", ui-monospace, monospace',
    theme: {
      background: "#efe9dc", foreground: "#4c473c", cursor: "#5e9c72", cursorAccent: "#faf6ee",
      selectionBackground: "#ddd3c0",
      black: "#4c473c", red: "#c25f50", green: "#5e9c72", yellow: "#b8862f",
      blue: "#5f83a8", magenta: "#9c7a9c", cyan: "#58948d", white: "#efe9dc",
      brightBlack: "#857d6b", brightRed: "#d07f6f", brightGreen: "#79b58c", brightYellow: "#cfa35a",
      brightBlue: "#7fa0c2", brightMagenta: "#b294b2", brightCyan: "#77aca5", brightWhite: "#faf6ee"
    }
  })
  const fit = new FitAddon.FitAddon()
  term.loadAddon(fit)
  term.open(document.getElementById("terminal"))
  fit.fit()

  const sub = createConsumer().subscriptions.create(
    { channel: "TerminalChannel", token: <%= token.to_json.html_safe %> },
    {
      connected() { this.perform("resize", { rows: term.rows, cols: term.cols }) },
      received(data) { term.write(Uint8Array.from(atob(data), c => c.charCodeAt(0))) },
      rejected() { term.write("\r\nCouldn't connect — reload the page to try again.\r\n") },
      disconnected() { term.write("\r\nConnection lost — reload the page to reconnect.\r\n") }
    }
  )

  // Copies happen inside tmux (drag-select, or apps like claude's "c to copy")
  // and arrive here as OSC 52 — xterm core ignores it, so bridge it to the
  // browser clipboard ourselves.
  term.parser.registerOscHandler(52, data => {
    try {
      const b64 = data.split(";")[1]
      if (!b64 || b64 === "?") return true // "?" is a clipboard read — unsupported
      const text = new TextDecoder().decode(Uint8Array.from(atob(b64), c => c.charCodeAt(0)))
      if (navigator.clipboard) {
        navigator.clipboard.writeText(text).catch(() => {})
      } else { // plain-http fallback: execCommand needs a real DOM selection
        const ta = document.createElement("textarea")
        ta.value = text
        document.body.append(ta)
        ta.select()
        document.execCommand("copy")
        ta.remove()
        term.focus()
      }
    } catch {} // bad base64 from a misbehaving app — never break the parser
    return true
  })

  // Claude rings the terminal bell when it finishes a turn and wants you — turn
  // that into a browser notification (permission is granted on the setup page).
  term.onBell(() => {
    if (window.Notification?.permission === "granted" && document.hidden) {
      try { new Notification(document.title, { body: "Claude is done — your turn." }) } catch {}
    }
  })

  // Voice = dictate in the browser (where you and the mic are) and type the
  // words straight into the terminal. Works even when claude runs on a headless
  // box, where its own /voice can't reach a microphone. Chrome/Edge only; the
  // button hides itself otherwise. Note: Chrome sends the audio to Google's
  // speech service for transcription.
  const mic = document.getElementById("mic")
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition
  if (mic && SR) {
    mic.hidden = false
    const rec = new SR()
    rec.continuous = true
    rec.interimResults = false
    rec.lang = navigator.language || "en-US"
    let on = false
    rec.onresult = e => {
      const text = Array.from(e.results).slice(e.resultIndex)
        .filter(r => r.isFinal).map(r => r[0].transcript).join("").trim()
      if (text) sub.perform("input", { data: text + " " })
    }
    rec.onend = () => { if (on) try { rec.start() } catch {} } // Chrome stops on silence — resume until toggled off
    rec.onerror = ev => { if (ev.error === "not-allowed") { on = false; mic.dataset.on = "false" } }
    mic.addEventListener("click", () => {
      on = !on
      mic.dataset.on = String(on)
      if (on) { try { rec.start() } catch {} } else rec.stop()
      term.focus()
    })
  }

  term.onData(data => sub.perform("input", { data }))
  addEventListener("resize", () => {
    fit.fit()
    sub.perform("resize", { rows: term.rows, cols: term.cols })
  })
  term.focus()
</script>
