<%# Browser terminal attached to the tmux session named by the signed token.
    xterm is vendored (vendor/javascript) — this page mints a shell-capability
    token, so no third-party JS. Render into a container with id "terminal". %>
<% content_for :head do %>
  <link rel="stylesheet" href="<%= asset_path("xterm.min.css") %>">
  <script src="<%= asset_path("xterm.min.js") %>"></script>
  <script src="<%= asset_path("addon-fit.min.js") %>"></script>
<% end %>

<script type="module">
  import { createConsumer } from "@rails/actioncable"

  await document.fonts.load('13px "IBM Plex Mono"') // xterm measures glyphs at open()

  const term = new Terminal({
    fontSize: 13,
    fontFamily: '"IBM Plex Mono", ui-monospace, monospace',
    theme: {
      background: "#efe9dc", foreground: "#4c473c", cursor: "#5e9c72", cursorAccent: "#faf6ee",
      selectionBackground: "#ddd3c0",
      black: "#4c473c", red: "#c25f50", green: "#5e9c72", yellow: "#b8862f",
      blue: "#5f83a8", magenta: "#9c7a9c", cyan: "#58948d", white: "#efe9dc",
      brightBlack: "#857d6b", brightRed: "#d07f6f", brightGreen: "#79b58c", brightYellow: "#cfa35a",
      brightBlue: "#7fa0c2", brightMagenta: "#b294b2", brightCyan: "#77aca5", brightWhite: "#faf6ee"
    }
  })
  const fit = new FitAddon.FitAddon()
  term.loadAddon(fit)
  term.open(document.getElementById("terminal"))
  fit.fit()

  const consumer = createConsumer()
  const sub = consumer.subscriptions.create(
    { channel: "TerminalChannel", token: <%= token.to_json.html_safe %> },
    {
      connected() { this.perform("resize", { rows: term.rows, cols: term.cols }) },
      received(data) { term.write(Uint8Array.from(atob(data), c => c.charCodeAt(0))) },
      rejected() { term.write("\r\nCouldn't connect — reload the page to try again.\r\n") },
      disconnected() { term.write("\r\nConnection lost — reload the page to reconnect.\r\n") }
    }
  )

  // Copies happen inside tmux (drag-select, or apps like claude's "c to copy")
  // and arrive here as OSC 52 — xterm core ignores it, so bridge it to the
  // browser clipboard ourselves.
  term.parser.registerOscHandler(52, data => {
    try {
      const b64 = data.split(";")[1]
      if (!b64 || b64 === "?") return true // "?" is a clipboard read — unsupported
      const text = new TextDecoder().decode(Uint8Array.from(atob(b64), c => c.charCodeAt(0)))
      if (navigator.clipboard) {
        navigator.clipboard.writeText(text).catch(() => {})
      } else { // plain-http fallback: execCommand needs a real DOM selection
        const ta = document.createElement("textarea")
        ta.value = text
        document.body.append(ta)
        ta.select()
        document.execCommand("copy")
        ta.remove()
        term.focus()
      }
    } catch {} // bad base64 from a misbehaving app — never break the parser
    return true
  })

  // Claude rings the terminal bell when it finishes a turn and wants you — turn
  // that into a browser notification (permission is granted on the setup page).
  term.onBell(() => {
    if (window.Notification?.permission === "granted" && document.hidden) {
      try { new Notification(document.title, { body: "Claude is done — your turn." }) } catch {}
    }
  })

  // Voice: stream the browser mic into the box's virtual microphone (MicChannel
  // → PulseAudio pipe-source), so claude's OWN /voice records it and transcribes
  // with Anthropic's model. Click 🎤 → it types /voice for you and arms the mic;
  // then HOLD SPACE to talk (matches claude's push-to-talk) and audio is sent
  // ONLY while Space is held. Click 🎤 again to leave voice mode.
  const mic = document.getElementById("mic")
  if (mic && navigator.mediaDevices?.getUserMedia && (window.AudioContext || window.webkitAudioContext)) {
    mic.hidden = false
    let stream, ctx, node, gain, armed = false, sending = false
    const disarm = () => {
      if (armed) sub.perform("input", { data: "\x1b" })      // Esc: leave claude's voice mode
      armed = sending = false; mic.dataset.on = "false"
      try { node?.disconnect(); gain?.disconnect(); ctx?.close() } catch {}
      stream?.getTracks().forEach(t => t.stop())
      stream = ctx = node = gain = null
    }
    const arm = async () => {
      try {
        stream = await navigator.mediaDevices.getUserMedia({ audio: { channelCount: 1, echoCancellation: true, noiseSuppression: true } })
      } catch { return } // mic denied
      try {
        ctx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: 16000 })
        const src = ctx.createMediaStreamSource(stream)
        node = ctx.createScriptProcessor(4096, 1, 1)         // deprecated but universal; no worklet asset
        node.onaudioprocess = e => {
          if (!sending) return                               // only while Space is held
          const f = e.inputBuffer.getChannelData(0)          // Float32 @16kHz mono
          const pcm = new Int16Array(f.length)               // → s16le for PulseAudio
          for (let i = 0; i < f.length; i++) pcm[i] = Math.max(-32768, Math.min(32767, f[i] < 0 ? f[i] * 0x8000 : f[i] * 0x7fff))
          const bytes = new Uint8Array(pcm.buffer)
          let bin = ""
          for (let i = 0; i < bytes.length; i++) bin += String.fromCharCode(bytes[i])
          micSub.perform("chunk", { data: btoa(bin) })
        }
        gain = ctx.createGain(); gain.gain.value = 0         // silent sink so onaudioprocess fires
        src.connect(node); node.connect(gain); gain.connect(ctx.destination)
        armed = true; mic.dataset.on = "true"
        sub.perform("input", { data: "/voice\r" })           // enter claude's voice mode for you
        term.focus()
      } catch { disarm() }
    }
    const micSub = consumer.subscriptions.create(
      { channel: "MicChannel", token: <%= token.to_json.html_safe %> },
      { rejected() { disarm(); mic.title = "Voice needs the box's audio set up first" } }
    )
    mic.addEventListener("click", () => armed ? disarm() : arm())
    // Gate the stream to Space-held. Capture phase so we still see it with the
    // terminal focused; we never preventDefault, so Space still reaches claude.
    addEventListener("keydown", e => { if (armed && e.code === "Space") sending = true }, true)
    addEventListener("keyup", e => { if (armed && e.code === "Space") sending = false }, true)
    addEventListener("blur", () => { sending = false })      // focus lost mid-hold → stop sending
  }

  term.onData(data => sub.perform("input", { data }))
  addEventListener("resize", () => {
    fit.fit()
    sub.perform("resize", { rows: term.rows, cols: term.cols })
  })
  term.focus()
</script>
