<% content_for :title, "Versions — #{@app.display_name}" %>

<section class="p-5 sm:p-7 max-w-3xl w-full mx-auto">
  <div class="flex items-baseline gap-4 mb-2">
    <h2 class="text-[11px] font-medium tracking-[0.3em] text-dim uppercase">Versions · <%= @app.display_name %></h2>
    <span class="flex-1 border-t border-line-soft"></span>
    <a href="<%= root_path %>" class="text-[11px] text-faint hover:text-dim">← back</a>
  </div>
  <p class="text-[11px] text-dim leading-relaxed mt-0 mb-6 max-w-2xl">
    Every save Claude makes is a version you can return to. Rolling back puts that exact version
    of your app live again — <strong class="text-strong">and rewinds your live data to that same moment</strong>.
    The app is briefly offline while it happens. Nothing is lost: newer changes stay in your history and backups.
  </p>

  <% if @commits.empty? %>
    <p class="text-[11px] text-idle">No versions yet — once Claude saves some work here, it shows up.</p>
  <% else %>
    <div class="border border-line bg-panel clip-tag divide-y divide-line-soft">
      <% @commits.each_with_index do |c, i| %>
        <div class="flex items-center gap-3 px-4 py-3">
          <div class="flex-1 min-w-0">
            <div class="text-[13px] text-strong truncate"><%= c[:subject].presence || c[:short] %></div>
            <div class="text-[10px] text-faint mt-0.5">
              <%= c[:short] %><% if c[:at] %> · <%= time_ago_in_words(c[:at]) %> ago<% end %>
              <% if i.zero? %> · <span class="text-live">current</span><% end %>
            </div>
          </div>
          <% if i.zero? %>
            <span class="text-[10px] tracking-[0.14em] text-faint px-3 py-1.5">LIVE NOW</span>
          <% else %>
            <%= button_to "ROLL BACK →", versions_rollback_path, params: { sha: c[:sha] },
                  class: "text-[10px] tracking-[0.14em] text-danger border border-danger/40 px-3 py-1.5 clip-tag hover:bg-danger/10 cursor-pointer bg-transparent shrink-0",
                  form: { class: "contents", onsubmit: "return confirm('Roll the live app back to this version? Both the code and the live data return to this point, and the app is briefly offline. Newer changes stay in your history.')" } %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
