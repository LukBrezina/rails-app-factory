#!/bin/sh
# Usage: bin/create-app NAME [GIT_URL]
# Run by the factory inside a visible "<name>--setup" tmux session, cwd = projects dir.
# Without GIT_URL: produces a vanilla rails+tailwind app that is factory-ready.
# With GIT_URL: clones an existing app — its config/rails_app_factory.rb tells
# the factory how to run it (see README: Hooks).
set -e
name="$1"
repo="$2"
[ -n "$name" ] || { echo "usage: bin/create-app NAME [GIT_URL]"; exit 1; }

if [ -n "$repo" ]; then
  git clone "$repo" "$name"
  cd "$name"
  echo
  echo "=> $name connected."
  if [ ! -f config/rails_app_factory.rb ]; then
    echo "   Note: no config/rails_app_factory.rb found — sessions will assume"
    echo "   bin/setup-worktree (optional) and bin/dev. Add the config file to"
    echo "   customise setup/server/teardown (see the factory README: Hooks)."
  fi
  exit 0
fi

rails new "$name" --css=tailwind
cd "$name"

bundle add aws-sdk-s3

mkdir -p bin

# ---------- worktree plumbing ----------
cat > bin/setup-worktree <<'EOS'
#!/bin/sh
# Prepare a fresh git worktree: copy untracked secrets from the main checkout,
# install dependencies, prepare the database. Run from the worktree root.
set -e
main="$(dirname "$(git rev-parse --path-format=absolute --git-common-dir)")"
for f in config/master.key .env .env.development; do
  if [ -f "$main/$f" ] && [ ! -f "$f" ]; then cp "$main/$f" "$f"; fi
done
bundle install
bin/rails db:prepare
EOS
chmod +x bin/setup-worktree

# ---------- backups: litestream config (env comes from kamal accessory) ----------
cat > config/litestream.yml <<'EOS'
# Streamed SQLite backups (rails-app-factory). Runs as a kamal accessory.
# retention is a year so litestream rarely attempts deletes — the hardened
# bucket denies them anyway (that is the point).
dbs:
  - path: /rails/storage/production.sqlite3
    replicas:
      - type: s3
        bucket: ${LITESTREAM_BUCKET}
        path: litestream/production
        region: ${LITESTREAM_REGION}
        endpoint: ${LITESTREAM_ENDPOINT}
        sync-interval: 30s
        snapshot-interval: 6h
        retention: 8760h
  - path: /rails/storage/production_queue.sqlite3
    replicas:
      - type: s3
        bucket: ${LITESTREAM_BUCKET}
        path: litestream/production_queue
        region: ${LITESTREAM_REGION}
        endpoint: ${LITESTREAM_ENDPOINT}
        sync-interval: 30s
        snapshot-interval: 6h
        retention: 8760h
EOS

# ---------- Active Storage → same hardened bucket in production ----------
cat >> config/storage.yml <<'EOS'

amazon:
  service: S3
  access_key_id: <%= ENV["S3_ACCESS_KEY_ID"] %>
  secret_access_key: <%= ENV["S3_SECRET_ACCESS_KEY"] %>
  region: <%= ENV.fetch("S3_REGION", "us-east-1") %>
  bucket: <%= ENV["S3_BUCKET"] %>
  <%= "endpoint: #{ENV["S3_ENDPOINT"]}" if ENV["S3_ENDPOINT"].to_s.length > 0 %>
EOS

cat >> config/environments/production.rb <<'EOS'

# rails-app-factory: attachments go to the hardened backups bucket when configured
Rails.application.configure do
  config.active_storage.service = :amazon if ENV["S3_BUCKET"].present?
end
EOS

cat > config/initializers/rails_app_factory.rb <<'EOS'
# rails-app-factory development conveniences (development only).
if Rails.env.development?
  # Allow preview access over tailscale.
  Rails.application.config.hosts << /.+\.ts\.net/

  # Capture every email the app "sends" into tmp/mails as a file, so the factory
  # can show it in a tidy inbox instead of it going to a real person.
  class RafMailbox
    def initialize(_settings = {}); end

    def deliver!(message)
      dir = Rails.root.join("tmp/mails")
      FileUtils.mkdir_p(dir)
      File.write(dir.join("#{Time.now.utc.strftime('%Y%m%d-%H%M%S-%9N')}.eml"), message.encoded)
      message
    end
  end

  ActionMailer::Base.add_delivery_method :raf_mailbox, RafMailbox
  ActionMailer::Base.delivery_method = :raf_mailbox
end
EOS

# ---------- factory hooks: how sessions run this app ----------
cat > config/rails_app_factory.rb <<'EOS'
# How Rails App Factory runs this app — plain Ruby, executed in each session's
# private workspace. Inside blocks: sh("...") runs a shell command and stops on
# failure; `app`, `session` and `port` identify this workspace; any Ruby works.

setup do
  sh "bin/setup-worktree"   # when a session starts — secrets, gems, database
end

server do
  sh "bin/dev"              # the test server — must listen on ENV["PORT"]
end

# When a session ends (e.g. drop a per-session Postgres database):
# teardown do
#   sh "dropdb --if-exists #{app}_dev_#{session}"
# end
EOS

# ---------- pull latest prod snapshot into a dev worktree ----------
cat > bin/pull-prod-data <<'EOS'
#!/bin/sh
# Pull the latest production database snapshot into this worktree's dev DB.
# Env (LITESTREAM_*) is provided by the factory when it opens the window.
set -e
: "${LITESTREAM_BUCKET:?LITESTREAM env missing — trigger this from the factory's Backups page}"
tmp="$(mktemp -u)"
litestream restore -o "$tmp" "s3://$LITESTREAM_BUCKET/litestream/production"
mkdir -p storage
mv "$tmp" storage/development.sqlite3
rm -f storage/development.sqlite3-wal storage/development.sqlite3-shm
echo "=> production data now in storage/development.sqlite3 — restart bin/dev (server window)"
EOS
chmod +x bin/pull-prod-data

# ---------- restore production to a point in time ----------
cat > bin/restore-prod <<'EOS'
#!/bin/sh
# Restore production to a point in time (UTC), e.g.: bin/restore-prod 2026-07-03T15:04:05Z
# Run from the app root on the factory machine; env comes from the factory.
set -e
ts="$1"
[ -n "$ts" ] || { echo "usage: bin/restore-prod TIMESTAMP"; exit 1; }
: "${LITESTREAM_BUCKET:?LITESTREAM env missing — trigger this from the factory's Backups page}"
app="$(basename "$PWD")"
img="litestream/litestream:0.3"

echo "=> stopping replication + app"
bin/kamal accessory stop litestream
bin/kamal app stop

for db in production production_queue; do
  echo "=> restoring $db to $ts"
  bin/kamal server exec "docker run --rm -v ${app}_storage:/data \
    -e LITESTREAM_ACCESS_KEY_ID='$LITESTREAM_ACCESS_KEY_ID' \
    -e LITESTREAM_SECRET_ACCESS_KEY='$LITESTREAM_SECRET_ACCESS_KEY' \
    $img restore -if-replica-exists -timestamp '$ts' -o /data/$db.restored \
    's3://$LITESTREAM_BUCKET/litestream/$db' && \
    docker run --rm -v ${app}_storage:/data alpine sh -c \
    'if [ -f /data/$db.restored ]; then mv /data/$db.restored /data/$db.sqlite3 && rm -f /data/$db.sqlite3-wal /data/$db.sqlite3-shm; fi'"
done

echo "=> booting app + replication"
bin/kamal app boot
bin/kamal accessory reboot litestream
echo "=> done — verify at your production URL"
EOS
chmod +x bin/restore-prod

git add -A
git commit -q -m "Add rails-app-factory plumbing (worktrees, backups, restore)" || true

echo
echo "=> $name is ready. Head back to the dashboard and launch a session."
