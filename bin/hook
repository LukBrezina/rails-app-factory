#!/usr/bin/env ruby
# Rails App Factory hook runner. Runs the Ruby blocks an app defines in
# config/rails_app_factory.rb (setup / server / teardown), falling back to the
# bin/ convention when a block is missing. Executed with the app's own Ruby,
# from the workspace root:
#   hook setup server   session start — visible in the session's server window
#   hook teardown       session end — before the workspace is deleted
#
# Keep this file compatible with old Rubies: connected apps may pin one.
class FactoryHooks
  HOOK_FILE = "config/rails_app_factory.rb".freeze

  def initialize
    @blocks = {}
    instance_eval(File.read(HOOK_FILE), HOOK_FILE) if File.exist?(HOOK_FILE)
  end

  # ---- DSL (the app's config file calls these) ----
  def setup(&block); @blocks[:setup] = block; end
  def server(&block); @blocks[:server] = block; end
  def teardown(&block); @blocks[:teardown] = block; end

  # ---- helpers available inside hook blocks ----
  def app; ENV["RAF_APP"].to_s; end
  def session; ENV["RAF_SESSION"].to_s; end
  def port; ENV["PORT"].to_s; end

  def sh(command)
    puts "» #{command}"
    system(command) || abort("hook failed: #{command}")
  end

  def run(name)
    block = @blocks[name]
    block ? instance_eval(&block) : run_default(name)
  end

  private

  def run_default(name)
    case name
    when :setup
      sh "bin/setup-worktree" if File.executable?("bin/setup-worktree")
    when :server
      sh "bin/dev"
    when :teardown
      sh "bin/teardown-worktree" if File.executable?("bin/teardown-worktree")
    end
  end
end

hooks = FactoryHooks.new
ARGV.each { |name| hooks.run(name.to_sym) }
