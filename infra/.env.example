# The ONE credentials file: cp .env.example .env, fill in, done.
# infra/customer sources it automatically — no exports, no openrc juggling.

# OpenStack (Infomaniak: Public Cloud project → Application Credentials;
# values match the downloadable openrc file)
OS_AUTH_URL=https://api.pub1.infomaniak.cloud/identity
OS_AUTH_TYPE=v3applicationcredential
OS_IDENTITY_API_VERSION=3
OS_INTERFACE=public
OS_REGION_NAME=dc3-a
OS_APPLICATION_CREDENTIAL_ID=
OS_APPLICATION_CREDENTIAL_SECRET=

# Mailgun (account API key)
MAILGUN_API_KEY=

# Google Cloud — service-account JSON with Storage Admin on the project
# (used for the per-customer buckets AND the tofu state bucket).
# Comment out to fall back to `gcloud auth application-default login`.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-key.json

# tofu inputs
TF_VAR_gcp_project=
TF_VAR_admin_cidr=203.0.113.7/32
TF_VAR_admin_ssh_pubkey="ssh-ed25519 AAAA... you@laptop"

# A SECOND OpenStack application credential — lives only on the admin box and
# runs its nightly backup cron. Create it by hand in the Infomaniak console
# (Identity → Application Credentials): an application credential cannot
# create another one, so tofu can't mint it for you.
TF_VAR_backup_credential_id=
TF_VAR_backup_credential_secret=
